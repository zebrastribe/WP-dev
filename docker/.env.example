MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root
WP_PORT=8888
WPDEV_PHP_VERSION=8.2
WP_HTTPS_PORT=8443
WPDEV_LOCAL_HTTPS=0
WPDEV_TERMINAL_PORT=7681
WPDEV_TERMINAL_RUNNER_PORT=7682
WPDEV_HOST_RUNNER_PORT=7683
# Basic auth for browser terminal (format: user:password)
WPDEV_TERMINAL_AUTH=change-me-user:change-me-password
# Required: shared secret for terminal runner API requests
WPDEV_TERMINAL_RUNNER_TOKEN=change-me-runner-token
# Allowed browser origin for terminal runner
WPDEV_TERMINAL_RUNNER_ORIGIN=http://localhost:8888
# Default browser-terminal working directory (must exist in container, e.g. /workspace)
WPDEV_TERMINAL_WORKDIR=/workspace

# Required: random secret; wizard sends X-WP-DEV-Admin-Token on save.
WPDEV_ADMIN_SAVE_TOKEN=change-me-admin-token

# Table prefix for local WordPress (must match imported DB if remote used a custom prefix).
# `wp-dev pull` updates this and wp-config.php when it can detect the prefix from the dump.
# WORDPRESS_TABLE_PREFIX=wp_
