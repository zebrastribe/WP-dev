MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root
WP_PORT=8888

# Recommended if WP_PORT is reachable from other machines: set a random secret; the wizard sends
# header X-WP-DEV-Admin-Token on save when this is non-empty (see README).
# WPDEV_ADMIN_SAVE_TOKEN=

# Table prefix for local WordPress (must match imported DB if remote used a custom prefix).
# Pull excludes wp-config.php; set this after pull when the dump uses e.g. clk1_…_options tables.
# WORDPRESS_TABLE_PREFIX=wp_
